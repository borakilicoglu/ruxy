{
  "name": "ruxy",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "turbo run dev",
    "dev:local": "./scripts/dev-local.sh",
    "dev:stack": "./scripts/dev.sh",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose stop db",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "prepare": "husky",
    "check:dashboard": "pnpm --filter dashboard build",
    "check:rust": "cargo check -p core-api -p proxy-server -p worker",
    "check": "pnpm check:dashboard && pnpm check:rust"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "turbo": "^2.0.0"
  }
}
